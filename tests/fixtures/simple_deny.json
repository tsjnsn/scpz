{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyS3Public",
      "Effect": "Deny",
      "Action": [
        "s3:PutBucketPublicAccessBlock",
        "s3:PutAccountPublicAccessBlock"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:PrincipalArn": "arn:aws:iam::root"
        }
      }
    }
  ]
}
